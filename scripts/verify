#!/usr/bin/env bash
set -euo pipefail

POSTGRES_PORT="${POSTGRES_PORT:-55432}"
BACKEND_PORT="${BACKEND_PORT:-18000}"
FRONTEND_PORT="${FRONTEND_PORT:-14200}"
COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT_NAME:-event_link_verify}"

cleanup() {
  COMPOSE_PROJECT_NAME="$COMPOSE_PROJECT_NAME" \
  POSTGRES_PORT="$POSTGRES_PORT" \
  BACKEND_PORT="$BACKEND_PORT" \
  FRONTEND_PORT="$FRONTEND_PORT" \
  docker compose down -v --remove-orphans >/dev/null 2>&1 || true
  rm -f .env
}
trap cleanup EXIT

python -m pip install --upgrade pip
pip install -r backend/requirements.txt ruff black
(cd ui && npm ci)
(cd backend && pytest -q)
(
  cd backend
  DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/eventlink_test \
  SECRET_KEY=integration-test-secret \
  EMAIL_ENABLED=false \
  RUN_INTEGRATION_TESTS=1 \
  pytest -q integration_tests
)
cp .env.example .env
COMPOSE_PROJECT_NAME="$COMPOSE_PROJECT_NAME" \
POSTGRES_PORT="$POSTGRES_PORT" \
BACKEND_PORT="$BACKEND_PORT" \
FRONTEND_PORT="$FRONTEND_PORT" \
docker compose up -d --build
for i in {1..90}; do
  if curl -fsS "http://localhost:${BACKEND_PORT}/api/health" >/dev/null; then
    break
  fi
  sleep 2
done
curl -fsS "http://localhost:${BACKEND_PORT}/api/health" >/dev/null
for i in {1..90}; do
  if curl -fsS "http://localhost:${FRONTEND_PORT}/" >/dev/null; then
    break
  fi
  sleep 2
done
curl -fsS "http://localhost:${FRONTEND_PORT}/" >/dev/null
(cd ui && npm test -- --watch=false --passWithNoTests)
