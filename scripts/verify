#!/usr/bin/env bash
set -euo pipefail
python -m pip install --upgrade pip
pip install -r backend/requirements.txt
(cd ui && npm ci)
make lint
(cd backend && pytest -q)
(
  cd backend
  DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/eventlink_test \
  SECRET_KEY=integration-test-secret \
  EMAIL_ENABLED=false \
  RUN_INTEGRATION_TESTS=1 \
  pytest -q integration_tests
)
cp .env.example .env
docker compose up -d --build
for i in {1..90}; do
  if curl -fsS "http://localhost:8000/api/health" >/dev/null; then
    break
  fi
  sleep 2
done
curl -fsS "http://localhost:8000/api/health" >/dev/null
for i in {1..90}; do
  if curl -fsS "http://localhost:4200/" >/dev/null; then
    break
  fi
  sleep 2
done
curl -fsS "http://localhost:4200/" >/dev/null
docker compose down -v
(cd ui && npm test -- --watch=false --passWithNoTests)
